# ============================================================================
# AI Daily Digest - Configuration
# ============================================================================
# Copy this file to .env and fill in your own values.
# All fields are optional unless you want the corresponding feature.
# ============================================================================

# ----------------------------------------------------------------------------
# Output Directory (for generated MD and HTML files)
# ----------------------------------------------------------------------------
# Where to save the generated AI_Builders_Digest_YYYY-MM-DD.md and .html files.
# Default: ./output (relative to the project root)
# Example: /home/user/ai-digest  or  E:\AI-Digest
OUTPUT_DIR=./output

# ----------------------------------------------------------------------------
# Feishu / Lark Integration (optional)
# ----------------------------------------------------------------------------
# To push digests to Feishu, you need:
#   1. Install lark-cli:  npm install -g @larksuiteoapi/lark-cli
#   2. Log in:            lark-cli auth login
#   3. Set the folder token where docs will be created
#
# The folder token can be found in the Feishu doc URL:
#   https://your-domain.feishu.cn/drive/folder/<FOLDER_TOKEN>
LARK_CLI_FOLDER_TOKEN=

# ----------------------------------------------------------------------------
# Proxy Settings (optional, if behind a firewall)
# ----------------------------------------------------------------------------
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ----------------------------------------------------------------------------
# Telegram Delivery (optional)
# ----------------------------------------------------------------------------
# Create a bot via @BotFather on Telegram, then paste the token here.
# TELEGRAM_BOT_TOKEN=

# ----------------------------------------------------------------------------
# Email Delivery via Resend (optional)
# ----------------------------------------------------------------------------
# Sign up at https://resend.com (free tier: 100 emails/day)
# RESEND_API_KEY=
